    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "lucide-vue-next": "^1.0.0",
    "motion": "^12.23.24",
    "vite": "^6.2.3",
    "vue": "^3.5.38"
  },
  "devDependencies": {
    "@types/canvas-confetti": "^1.9.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
